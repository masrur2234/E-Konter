generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== USER & AUTH ====================

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  password        String
  name            String
  phone           String?
  avatar          String?
  role            String   @default("owner") // owner, admin, kasir, super_admin
  status          String   @default("active") // active, suspended
  
  // Subscription
  subscriptionStatus String   @default("trial") // trial, active, expired
  trialStart         DateTime?
  trialEnd           DateTime?
  subscriptionStart  DateTime?
  subscriptionEnd    DateTime?
  planType           String?  // monthly, yearly
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores       Store[]
  products     Product[]
  customers    Customer[]
  transactions Transaction[]
  cashflows    Cashflow[]
  activityLogs ActivityLog[]

  @@map("users")
}

// ==================== STORES ====================

model Store {
  id          String   @id @default(cuid())
  userId      String
  name        String
  address     String?
  phone       String?
  whatsapp    String?
  logo        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]
  transactions Transaction[]
  customers Customer[]
  cashflows Cashflow[]
  activityLogs ActivityLog[]

  @@map("stores")
}

// ==================== PRODUCT CATEGORIES ====================

model Category {
  id        String   @id @default(cuid())
  userId    String
  storeId   String?
  name      String
  type      String   // phone, accessory, pulsa, paket_data, token_listrik
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("categories")
}

// ==================== PRODUCTS ====================

model Product {
  id          String   @id @default(cuid())
  userId      String
  storeId     String
  categoryId  String?
  
  // Product info
  name        String
  sku         String?
  type        String   // phone, accessory, pulsa, paket_data, token_listrik
  description String?  @db.Text
  
  // Phone specific
  brand       String?
  model       String?
  ram         String?
  storage     String?
  color       String?
  imei        String?
  condition   String?  // new, used, refurbished
  
  // Pricing & Stock
  buyPrice    Float    @default(0)
  sellPrice   Float    @default(0)
  stock       Int      @default(0)
  minStock    Int      @default(5)
  
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category   Category? @relation(fields: [categoryId], references: [id])
  items      TransactionItem[]

  @@map("products")
}

// ==================== CUSTOMERS ====================

model Customer {
  id        String   @id @default(cuid())
  userId    String
  storeId   String
  name      String
  phone     String?
  address   String?
  email     String?
  debt      Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("customers")
}

// ==================== TRANSACTIONS ====================

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  storeId     String
  customerId  String?
  cashierName String?
  
  invoiceNo   String   @unique
  type        String   @default("sale") // sale, purchase, pulsa
  
  subtotal    Float    @default(0)
  discount    Float    @default(0)
  total       Float    @default(0)
  paid        Float    @default(0)
  change      Float    @default(0)
  
  paymentMethod String  @default("cash") // cash, transfer, qris
  paymentRef   String?
  
  status      String   @default("completed") // completed, pending, cancelled
  
  // Receipt snapshot
  receiptData String?  @db.Text
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  store      Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer   Customer? @relation(fields: [customerId], references: [id])
  items      TransactionItem[]

  @@map("transactions")
}

// ==================== TRANSACTION ITEMS ====================

model TransactionItem {
  id           String   @id @default(cuid())
  transactionId String
  productId    String?
  
  productName  String
  category     String?
  quantity     Int      @default(1)
  buyPrice     Float    @default(0)
  sellPrice    Float    @default(0)
  total        Float    @default(0)

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product     Product?    @relation(fields: [productId], references: [id])

  @@map("transaction_items")
}

// ==================== CASHFLOW ====================

model Cashflow {
  id          String   @id @default(cuid())
  userId      String
  storeId     String
  
  type        String   // income, expense, transfer
  category    String?  // sales, pulsa, purchase, salary, rent, utility, etc
  amount      Float
  description String?
  reference   String?
  
  // For transfers
  fromStoreId String?
  toStoreId   String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("cashflows")
}

// ==================== PULSA TRANSACTIONS ====================

model PulsaTransaction {
  id          String   @id @default(cuid())
  userId      String
  storeId     String
  customerId  String?
  
  phone       String
  type        String   // pulsa, paket_data, token_listrik
  operator    String?
  nominal     String
  price       Float
  
  status      String   @default("pending") // pending, success, failed
  refId       String?
  provider    String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("pulsa_transactions")
}

// ==================== ACTIVITY LOG ====================

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  storeId     String?
  action      String
  description String
  metadata    String?  @db.Text
  createdAt   DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  store      Store?   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}
